# =============================================================================
# Servidor
# =============================================================================
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:4200

# =============================================================================
# Base de datos activa: HANA | SQLSERVER | POSTGRES
# =============================================================================
DB_TYPE=HANA

# =============================================================================
# Modo de operación
# =============================================================================
# APP_MODE:  ONLINE (requiere SAP Service Layer) | OFFLINE (solo Postgres)
#
# Combinaciones válidas:
#   DB_TYPE=HANA      + APP_MODE=ONLINE   → HANA + SAP Service Layer
#   DB_TYPE=SQLSERVER + APP_MODE=ONLINE   → SQL Server + SAP Service Layer
#   DB_TYPE=POSTGRES  + APP_MODE=OFFLINE  → Postgres sin SAP Service Layer
# =============================================================================
APP_MODE=ONLINE

# =============================================================================
# SAP HANA
# =============================================================================
HANA_HOST=localhost
HANA_PORT=30015
HANA_USER=SYSTEM
HANA_PASSWORD=your-password-here
HANA_SCHEMA=REND_RETAIL
HANA_ENCRYPT=false
HANA_SSL_VALIDATE_CERTIFICATE=false

# =============================================================================
# SQL Server (solo cuando DB_TYPE=SQLSERVER)
# =============================================================================
SQL_HOST=localhost
SQL_PORT=1433
SQL_USER=sa
SQL_PASSWORD=your-password-here
SQL_DATABASE=rendiciones

# =============================================================================
# PostgreSQL (solo cuando DB_TYPE=POSTGRES)
# =============================================================================
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your-password-here
PG_DATABASE=rendiciones

# =============================================================================
# SAP Service Layer (requerido en APP_MODE=ONLINE)
# =============================================================================
SAP_SL_URL=https://localhost:50000/b1s/v1
SAP_SL_USER=manager
SAP_SL_PASSWORD=your-password-here
SAP_SL_COMPANY=SBODEMOBR

# =============================================================================
# JWT
# =============================================================================
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=1d

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=debug
LOG_DIR=logs

# =============================================================================
# Archivos adjuntos
# =============================================================================
UPLOAD_DIR=./uploads

# =============================================================================
# Inteligencia Artificial (IA) — opcional
# =============================================================================
IA_ENABLED=false
IA_PROVIDER=anthropic

# Anthropic (requerido si IA_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# OpenAI (requerido si IA_PROVIDER=openai)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
