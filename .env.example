# Servidor
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:4200

# Base de datos activa: HANA | SQL
DB_TYPE=HANA

# SAP HANA
HANA_HOST=hanaroda25.gruporoda.com
HANA_PORT=30015
HANA_USER=B1ADMIN
HANA_PASSWORD=your-password-here
HANA_SCHEMA=REND_RETAIL
HANA_ENCRYPT=false
HANA_SSL_VALIDATE_CERTIFICATE=false

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=1d

# Logging
LOG_LEVEL=debug
LOG_DIR=logs

# =============================================================================
# Modo de operación
# =============================================================================
# DB_TYPE:   HANA | SQLSERVER | POSTGRES
# APP_MODE:  ONLINE (SAP Service Layer) | OFFLINE (solo Postgres)
#
# Combinaciones válidas:
#   DB_TYPE=HANA      + APP_MODE=ONLINE   → HANA + SAP Service Layer
#   DB_TYPE=SQLSERVER + APP_MODE=ONLINE   → SQL Server + SAP Service Layer
#   DB_TYPE=POSTGRES  + APP_MODE=OFFLINE  → Postgres sin SAP Service Layer
# =============================================================================
APP_MODE=ONLINE

# Inteligencia Artificial (IA)
IA_ENABLED=false
IA_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
